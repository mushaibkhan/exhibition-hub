# Development and production. Copy to .env (dev) or .env.production (prod) and set values.
# API (apps/api): PORT, DATABASE_URL, REDIS_URL, JWT_SECRET, JWT_EXPIRES_IN, NODE_ENV
# Docker production compose: DB_PASSWORD, JWT_SECRET
# Frontend build: VITE_API_URL

PORT=4000
DATABASE_URL=postgresql://app_user:devpassword123@localhost:5432/exhibition_hub
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development

DB_PASSWORD=devpassword123
VITE_API_URL=http://localhost:4000/api
